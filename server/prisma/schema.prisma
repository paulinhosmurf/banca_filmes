// ============================================================================
// BANCA DOS FILMES — Prisma Schema
// ============================================================================
// Segurança em nível de banco de dados:
// - Prisma gera queries 100% parametrizadas → imune a SQL Injection
// - UNIQUE constraints em Like e Favorite → impede duplicatas mesmo sob
//   race conditions (o banco REJEITA a segunda inserção)
// - onDelete: Cascade → limpa dados órfãos automaticamente
// - CUIDs como IDs → não expõem contagem de registros
// ============================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

// ─── Users ──────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String   // Hash bcrypt — NUNCA armazena texto plano
  role      Role     @default(USER)
  avatar    String?  // URL externa do avatar (opcional)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  comments  Comment[]
  likes     Like[]
  favorites Favorite[]

  @@map("users")
}

// ─── Movies ─────────────────────────────────────────────────────────────────

model Movie {
  id          String   @id @default(cuid())
  title       String
  synopsis    String   @db.Text
  posterUrl   String   // URL externa do poster
  videoUrl    String   // URL externa do vídeo (YouTube, Drive, etc.)
  trailerUrl  String?  // URL do trailer (opcional)
  genre       String[] // Array de gêneros: ["Ação", "Ficção Científica"]
  year        Int
  duration    Int?     // Duração em minutos
  director    String?
  cast        String[] // Array de atores
  rating      Float    @default(0)
  featured    Boolean  @default(false) // Destaque na home
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relações
  comments  Comment[]
  likes     Like[]
  favorites Favorite[]

  @@index([title])    // Index para busca por título
  @@index([year])     // Index para filtro por ano
  @@map("movies")
}

// ─── Comments ───────────────────────────────────────────────────────────────
// O conteúdo é sanitizado com DOMPurify ANTES de ser persistido.
// Nunca armazenamos HTML não-sanitizado.

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text // Sanitizado via DOMPurify no controller
  userId    String
  movieId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@index([movieId]) // Index para listar comentários de um filme
  @@map("comments")
}

// ─── Likes ──────────────────────────────────────────────────────────────────
// A UNIQUE constraint [userId, movieId] garante:
// 1. Um usuário NÃO PODE curtir o mesmo filme duas vezes
// 2. Mesmo com race conditions (dois requests simultâneos), o banco REJEITA
//    a segunda inserção com erro de constraint violation

model Like {
  id        String   @id @default(cuid())
  userId    String
  movieId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId]) // PROTEÇÃO CONTRA DUPLICATAS
  @@map("likes")
}

// ─── Favorites ──────────────────────────────────────────────────────────────
// Mesma lógica de proteção do Like — constraint unique no par userId+movieId

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  movieId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId]) // PROTEÇÃO CONTRA DUPLICATAS
  @@map("favorites")
}
