# ============================================================================
# Variáveis de Ambiente — EXEMPLO (NÃO contém valores reais)
# ============================================================================
# Copie para .env e preencha. Em produção, use Vercel/Railway env vars.
# NUNCA commite o .env real no repositório.
# ============================================================================

# ─── Servidor ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Banco de Dados (PostgreSQL) ─────────────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:senha@localhost:5432/banca_filmes

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=sua-chave-secreta-com-no-minimo-32-caracteres-aqui
JWT_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── CSRF ────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=sua-chave-csrf-com-no-minimo-32-caracteres-aqui
